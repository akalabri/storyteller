# ─────────────────────────────────────────────────────────────
# Vibe Story Lab — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ─────────────────────────────────
# API key from Google AI Studio or GCP Console
GOOGLE_API_KEY=

# Path to your GCP service account key JSON file (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS="key.json"

# GCP project and region for Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Set to true to route all google-genai calls through Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true

# ── Veo (Video Generation) ──────────────────────────────────
# GCS bucket used for Veo input/output (must exist in your GCP project)
VEO_BUCKET=your-veo-bucket-name

# ── ElevenLabs (Narration / TTS) ────────────────────────────
ELEVENLABS_API_KEY=

# ── FAL (Optional — fallback video generation) ──────────────
FAL_API_KEY=

# ── RabbitMQ (Task queue broker) ─────────────────────────────
# Connection URL for Celery — matches the RabbitMQ service in docker-compose.yml
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# ── MinIO (Local artifact storage) ──────────────────────────
# These match the defaults in docker-compose.yml — change if needed
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio1234
MINIO_BUCKET=storyteller

# ── Pipeline Settings ───────────────────────────────────────
# Set to 1 to run all generation steps sequentially (avoids rate limits)
SEQUENTIAL_GENERATION=0

# ── Dev Mode (Optional) ─────────────────────────────────────
# When DEV_MODE=1, only the steps listed in DEV_STEPS are executed.
# All other steps load cached artifacts from sessions/DEV_SESSION_ID/.
# Valid step names: story_breakdown, narration, character_images,
#                   scene_prompts, scene_images, scene_videos, compile
DEV_MODE=0
DEV_SESSION_ID=dev_session
DEV_STEPS=
